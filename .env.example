# Optional: load images from Cloudinary (browser-only, no backend).
# Portfolio uses only Cloudinary (tag from REACT_APP_PORTFOLIO_DIR) or REACT_APP_PORTFOLIO_IMAGES_URL — no local bundle.
# Main slider: Cloudinary / JSON, or bundled files in src/assets/main-slide if unset.

# --- Cloudinary (no backend, no API keys in the app) ---
# 1. Sign up at https://cloudinary.com (free).
# 2. In Dashboard → Settings → Security, enable "Resource list" under Restricted image types.
# 3. Set your cloud name and the "dir" name for each gallery (same name you'll use as tag in Cloudinary).
REACT_APP_CLOUDINARY_CLOUD_NAME=your_cloud_name
REACT_APP_PORTFOLIO_DIR=portfolio
REACT_APP_MAINSLIDE_DIR=main-slide

# In Cloudinary: tag images with these exact names (e.g. tag "portfolio" → portfolio page, "main-slide" → homepage slider). No backend needed.
# Service / about images: same cloud; tag = folder name under src/img — profile, evening-makeup, bridal-makeup, face-painting, eyebrow, personal-makeup-workshop.

# --- Or: JSON URLs (array of image URLs) ---
# REACT_APP_PORTFOLIO_IMAGES_URL=https://example.com/portfolio.json
# REACT_APP_MAINSLIDE_IMAGES_URL=https://example.com/main-slide.json
